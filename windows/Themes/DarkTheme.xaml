<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== DARK THEME — Windows 11 Fluent Design ===== -->

    <!-- Core surface colors -->
    <Color x:Key="WindowBackgroundColor">#202020</Color>
    <Color x:Key="CardBackgroundColor">#2C2C2C</Color>
    <Color x:Key="CardBorderColor">#3A3A3A</Color>
    <Color x:Key="SurfaceVariantColor">#272727</Color>

    <!-- Text colors -->
    <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
    <Color x:Key="SecondaryTextColor">#ABABAB</Color>
    <Color x:Key="DisabledTextColor">#636363</Color>
    <Color x:Key="HintTextColor">#6B6B6B</Color>

    <!-- Accent (Windows Blue — slightly brighter for dark) -->
    <Color x:Key="AccentColor">#60CDFF</Color>
    <Color x:Key="AccentHoverColor">#4CC4F7</Color>
    <Color x:Key="AccentPressedColor">#3AB6E8</Color>
    <Color x:Key="AccentSubtleColor">#1A2D3D</Color>
    <Color x:Key="AccentSubtleBorderColor">#1E4E79</Color>

    <!-- Danger / Stop -->
    <Color x:Key="DangerColor">#FF6B6B</Color>
    <Color x:Key="DangerHoverColor">#FF5252</Color>
    <Color x:Key="DangerSubtleColor">#3D1C1C</Color>

    <!-- Success / Running -->
    <Color x:Key="SuccessColor">#6CCB5F</Color>
    <Color x:Key="SuccessSubtleColor">#1A2E1A</Color>

    <!-- Input fields -->
    <Color x:Key="InputBackgroundColor">#3A3A3A</Color>
    <Color x:Key="InputBorderColor">#4D4D4D</Color>
    <Color x:Key="InputFocusBorderColor">#60CDFF</Color>

    <!-- Progress bar -->
    <Color x:Key="ProgressTrackColor">#3A3A3A</Color>
    <Color x:Key="ProgressFillColor">#60CDFF</Color>

    <!-- Toggle switch -->
    <Color x:Key="ToggleOffTrackColor">#6B6B6B</Color>
    <Color x:Key="ToggleOffThumbColor">#FFFFFF</Color>

    <!-- Shadow -->
    <Color x:Key="ShadowColor">#28000000</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="{StaticResource SurfaceVariantColor}"/>

    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}"/>
    <SolidColorBrush x:Key="HintTextBrush" Color="{StaticResource HintTextColor}"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtleColor}"/>
    <SolidColorBrush x:Key="AccentSubtleBorderBrush" Color="{StaticResource AccentSubtleBorderColor}"/>

    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}"/>
    <SolidColorBrush x:Key="DangerSubtleBrush" Color="{StaticResource DangerSubtleColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessSubtleBrush" Color="{StaticResource SuccessSubtleColor}"/>

    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="{StaticResource InputFocusBorderColor}"/>

    <SolidColorBrush x:Key="ProgressTrackBrush" Color="{StaticResource ProgressTrackColor}"/>
    <SolidColorBrush x:Key="ProgressFillBrush" Color="{StaticResource ProgressFillColor}"/>

    <SolidColorBrush x:Key="ToggleOffTrackBrush" Color="{StaticResource ToggleOffTrackColor}"/>
    <SolidColorBrush x:Key="ToggleOffThumbBrush" Color="{StaticResource ToggleOffThumbColor}"/>

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#2C2C2C"/>
    <SolidColorBrush x:Key="TitleBarForegroundBrush" Color="{StaticResource PrimaryTextColor}"/>

    <!-- Separator line -->
    <SolidColorBrush x:Key="SeparatorBrush" Color="#3A3A3A"/>

</ResourceDictionary>
