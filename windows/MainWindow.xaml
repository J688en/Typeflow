<Window x:Class="TypeFlow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TypeFlow.ViewModels"
        Title="TypeFlow"
        Width="520" Height="680"
        MinWidth="480" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="{StaticResource SegoeUI}"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- Root grid: title bar + content -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Custom title bar -->
            <RowDefinition Height="*"/>    <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             TITLE BAR
        ══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource TitleBarBackgroundBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App icon + name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="14,0,0,0">
                    <!-- Inline SVG-style app icon -->
                    <Canvas Width="24" Height="24" Margin="0,0,8,0">
                        <!-- Keyboard base -->
                        <Rectangle Canvas.Left="1" Canvas.Top="6"
                                   Width="22" Height="14" RadiusX="3" RadiusY="3"
                                   Fill="{DynamicResource AccentBrush}"/>
                        <!-- Key dots -->
                        <Rectangle Canvas.Left="4"  Canvas.Top="9"  Width="3" Height="2" RadiusX="0.5" RadiusY="0.5" Fill="White" Opacity="0.9"/>
                        <Rectangle Canvas.Left="9"  Canvas.Top="9"  Width="3" Height="2" RadiusX="0.5" RadiusY="0.5" Fill="White" Opacity="0.9"/>
                        <Rectangle Canvas.Left="14" Canvas.Top="9"  Width="3" Height="2" RadiusX="0.5" RadiusY="0.5" Fill="White" Opacity="0.9"/>
                        <Rectangle Canvas.Left="19" Canvas.Top="9"  Width="2" Height="2" RadiusX="0.5" RadiusY="0.5" Fill="White" Opacity="0.9"/>
                        <Rectangle Canvas.Left="4"  Canvas.Top="13" Width="3" Height="2" RadiusX="0.5" RadiusY="0.5" Fill="White" Opacity="0.9"/>
                        <Rectangle Canvas.Left="9"  Canvas.Top="13" Width="8" Height="2" RadiusX="0.5" RadiusY="0.5" Fill="White" Opacity="0.9"/>
                        <Rectangle Canvas.Left="19" Canvas.Top="13" Width="2" Height="2" RadiusX="0.5" RadiusY="0.5" Fill="White" Opacity="0.9"/>
                        <!-- Cursor blink dot -->
                        <Ellipse Canvas.Left="7" Canvas.Top="1" Width="5" Height="5"
                                 Fill="{DynamicResource AccentBrush}"/>
                        <Ellipse Canvas.Left="8" Canvas.Top="2" Width="3" Height="3"
                                 Fill="White" Opacity="0.85"/>
                    </Canvas>

                    <TextBlock Text="TypeFlow"
                               Style="{StaticResource HeadingText}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TitleBarForegroundBrush}"/>
                </StackPanel>

                <!-- Status pill in center -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{Binding Status, Converter={StaticResource StatusToColor}}"/>
                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                               Style="{StaticResource LabelText}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Theme toggle button -->
                <Button Grid.Column="2" x:Name="ThemeToggleBtn"
                        Content="☀" FontSize="16"
                        Style="{StaticResource SecondaryButton}"
                        Padding="8,4"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        ToolTip="Toggle light/dark theme"
                        Click="ThemeToggleBtn_Click"
                        BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             MAIN CONTENT AREA
        ══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16,12,16,16" x:Name="ContentPanel">

                <!-- ── Text input card ──────────────────────────── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Text to Type"
                                       Style="{StaticResource HeadingText}"/>
                            <!-- Character/word counter -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource LabelText}" FontSize="12">
                                    <Run Text="{Binding CharacterCount, Mode=OneWay}"/>
                                    <Run Text=" chars · "/>
                                    <Run Text="{Binding WordCount, Mode=OneWay}"/>
                                    <Run Text=" words"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <!-- Multi-line text input -->
                        <TextBox x:Name="InputTextBox"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="Wrap"
                                 Height="160"
                                 VerticalScrollBarVisibility="Auto"
                                 IsEnabled="{Binding IsIdle}"
                                 VerticalAlignment="Stretch"/>

                        <!-- Placeholder text overlay -->
                        <TextBlock IsHitTestVisible="False"
                                   Text="Paste or type your text here…"
                                   Foreground="{DynamicResource HintTextBrush}"
                                   FontStyle="Italic"
                                   FontSize="14"
                                   Margin="12,-152,0,0"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Left">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding InputText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Clear button -->
                        <Button Content="Clear text"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Right"
                                Margin="0,8,0,0"
                                Padding="12,5"
                                IsEnabled="{Binding IsIdle}"
                                Click="ClearText_Click"/>
                    </StackPanel>
                </Border>

                <!-- ── WPM slider card ──────────────────────────── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Typing Speed"
                                       Style="{StaticResource HeadingText}"/>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource AccentSubtleBrush}"
                                    BorderBrush="{DynamicResource AccentSubtleBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8,3">
                                <TextBlock Text="{Binding WpmLabel}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="13"/>
                            </Border>
                        </Grid>

                        <Slider Minimum="30" Maximum="120"
                                Value="{Binding Wpm}"
                                IsSnapToTickEnabled="True"
                                TickFrequency="5"
                                IsEnabled="{Binding IsIdle}"
                                Height="22"/>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="30 WPM" Style="{StaticResource LabelText}" FontSize="11" HorizontalAlignment="Left"/>
                            <TextBlock Grid.Column="1" Text="Slow · Normal · Fast" Style="{StaticResource LabelText}" FontSize="11" HorizontalAlignment="Center" Opacity="0.6"/>
                            <TextBlock Grid.Column="2" Text="120 WPM" Style="{StaticResource LabelText}" FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Options card ──────────────────────────────── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Options"
                                   Style="{StaticResource HeadingText}"
                                   Margin="0,0,0,14"/>

                        <!-- Typo simulation toggle -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Typo Simulation"
                                           Style="{StaticResource BaseText}"
                                           FontWeight="Medium"/>
                                <TextBlock Text="Occasionally mis-types and self-corrects (~4% of letters)"
                                           Style="{StaticResource LabelText}"
                                           FontSize="12"
                                           Margin="0,2,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding TypoEnabled}"
                                      IsEnabled="{Binding IsIdle}"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Background="{DynamicResource SeparatorBrush}" Margin="0,0,0,14"/>

                        <!-- Start method -->
                        <TextBlock Text="Start Method"
                                   Style="{StaticResource BaseText}"
                                   FontWeight="Medium"
                                   Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="5-second countdown"
                                         GroupName="StartMethod"
                                         IsChecked="{Binding SelectedStartMethod,
                                             Converter={StaticResource EnumToBool},
                                             ConverterParameter=Countdown}"
                                         IsEnabled="{Binding IsIdle}"/>
                            <RadioButton Content="Hotkey (Ctrl+Shift+T)"
                                         GroupName="StartMethod"
                                         IsChecked="{Binding SelectedStartMethod,
                                             Converter={StaticResource EnumToBool},
                                             ConverterParameter=Hotkey}"
                                         IsEnabled="{Binding IsIdle}"/>
                        </StackPanel>

                        <!-- Hotkey hint -->
                        <Border Background="{DynamicResource AccentSubtleBrush}"
                                BorderBrush="{DynamicResource AccentSubtleBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="10,8"
                                Margin="0,10,0,0">
                            <TextBlock Style="{StaticResource LabelText}" FontSize="12"
                                       TextWrapping="Wrap">
                                <Run FontWeight="SemiBold"
                                     Foreground="{DynamicResource AccentBrush}">Hotkeys: </Run>
                                <Run>Ctrl+Shift+T to start · Ctrl+Shift+S or Esc to stop</Run>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ── Progress card ─────────────────────────────── -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Progress"
                                       Style="{StaticResource HeadingText}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Progress, Converter={StaticResource DoubleToPercent}}"
                                       Style="{StaticResource LabelText}"
                                       FontWeight="SemiBold"/>
                        </Grid>

                        <ProgressBar Value="{Binding Progress}"
                                     Minimum="0" Maximum="1"/>

                        <!-- Status message -->
                        <TextBlock Text="{Binding StatusMessage}"
                                   Style="{StaticResource LabelText}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0"
                                   Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <!-- ── Action buttons ─────────────────────────────── -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="▶  Start Typing"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding StartTypingCommand}"
                            Height="44"
                            FontSize="15"/>

                    <Button Grid.Column="2"
                            Content="■  Stop"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding StopTypingCommand}"
                            Height="44"
                            Width="100"
                            FontSize="15"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════════════════════════════════════════════
             COUNTDOWN OVERLAY
        ══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              Visibility="{Binding CountdownVisible, Converter={StaticResource BoolToVisibility}}">

            <!-- Semi-transparent backdrop -->
            <Rectangle Fill="#CC000000"/>

            <!-- Countdown panel -->
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="40,32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="280">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.35"
                                      BlurRadius="32" ShadowDepth="4"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Starting in…"
                               Style="{StaticResource LabelText}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding CountdownSeconds}"
                               Style="{StaticResource CountdownText}"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Move cursor to your target application"
                               Style="{StaticResource LabelText}"
                               FontSize="13"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               MaxWidth="220"
                               Margin="0,12,0,16"/>

                    <Button Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding StopTypingCommand}"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
