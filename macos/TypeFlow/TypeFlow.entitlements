<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- 
	    TypeFlow requires Accessibility entitlement to post CGEvents
	    to other applications (keystroke simulation).
	    NOTE: com.apple.security.temporary-exception.accessibility is NOT
	    available for Mac App Store distribution. For distribution outside
	    the App Store (direct/notarized), the user must manually grant
	    Accessibility permission in System Settings > Privacy & Security.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<!--
	    Sandbox must be disabled for CGEvent-based keystroke injection
	    to work across applications. If you wish to sandbox the app,
	    you would need to use a different IPC approach (e.g., the
	    Accessibility API with a helper tool).
	-->
</dict>
</plist>
