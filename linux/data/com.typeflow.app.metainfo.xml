<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.typeflow.app</id>

  <name>TypeFlow</name>
  <summary>Simulate natural human typing into any application</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      TypeFlow lets you paste a block of text and then simulates it being typed
      naturally — character by character, with randomized timing to mimic real
      human keystrokes.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Adjustable typing speed from 30 to 120 WPM</li>
      <li>Typo simulation with automatic correction</li>
      <li>5-second countdown mode or global hotkey trigger</li>
      <li>Escape key or Ctrl+Shift+S to stop at any time</li>
      <li>Live progress bar showing typing completion</li>
      <li>Works on both X11 and Wayland</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.typeflow.app.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <caption>Main TypeFlow window</caption>
      <image type="source">https://raw.githubusercontent.com/typeflow/typeflow/main/screenshots/main.png</image>
    </screenshot>
  </screenshots>

  <url type="homepage">https://github.com/typeflow/typeflow</url>
  <url type="bugtracker">https://github.com/typeflow/typeflow/issues</url>

  <releases>
    <release version="1.0.0" date="2024-01-01">
      <description>
        <p>Initial release of TypeFlow.</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1" />

  <recommends>
    <display_length compare="ge">360</display_length>
  </recommends>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>

  <provides>
    <binary>typeflow</binary>
  </provides>

  <keywords>
    <keyword>typing</keyword>
    <keyword>keyboard</keyword>
    <keyword>automation</keyword>
    <keyword>simulate</keyword>
    <keyword>accessibility</keyword>
  </keywords>
</component>
