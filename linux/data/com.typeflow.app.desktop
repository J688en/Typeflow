[Desktop Entry]
Name=TypeFlow
GenericName=Typing Simulator
Comment=Simulate natural human typing into any application
Exec=typeflow
Icon=com.typeflow.app
Terminal=false
Type=Application
Categories=Utility;Accessibility;
Keywords=typing;automation;simulate;type;keyboard;
StartupNotify=true
StartupWMClass=TypeFlow

# Wayland/X11 support
X-KDE-Protocols=wayland;x11;
